# 会场精灵 - 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置
# ============================================

# 完整连接URL (推荐)
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/event_assistant?charset=utf8mb4

# 或者分项配置
#DB_USER=root
#DB_PASSWORD=your_password
#DB_HOST=localhost
#DB_PORT=3306
#DB_NAME=event_assistant

# ============================================
# 应用配置
# ============================================

# 应用密钥 (用于session等加密)
SECRET_KEY=your-secret-key-here-change-in-production

# 调试模式
DEBUG=True

# 应用端口
PORT=8000

# ============================================
# 可选: 外部服务配置
# ============================================

# 地图API密钥 (高德/百度)
MAP_API_KEY=your-map-api-key

# AI服务配置
AI_API_KEY=your-ai-api-key
AI_API_URL=https://api.example.com/v1/chat

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB
